# Server
WL_PORT=3000

# Webhook limits
WL_MAX_ITEMS_PER_ENDPOINT=50
WL_MAX_ENDPOINTS_PER_USER=20

# Auth
WL_COOKIE_NAME=wl_session
WL_COOKIE_MAX_AGE_DAYS=30
WL_COOKIE_SECRET=change-me-to-a-random-64-char-hex-string

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=your-password-here

# Admin
WL_ADMIN_KEY=
