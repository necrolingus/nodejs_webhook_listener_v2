# Server
WL_PORT=3088
# Number of reverse proxies in front of this app (0 = none, 1 = one proxy like nginx, etc.)
WL_TRUST_PROXY=2

# Webhook limits
WL_MAX_ITEMS_PER_ENDPOINT=30
WL_MAX_ENDPOINTS_PER_USER=15

# Auth
WL_COOKIE_NAME=wl_session
WL_COOKIE_MAX_AGE_DAYS=30
WL_COOKIE_SECRET=any 64 char hex string

# Database
DB_FILE=data/webhook_listener.db

# Admin
WL_ADMIN_KEY=
